function renderTable(tableId, data, renderFunction) {
    const $tbody = $(`#${tableId}`);
    $tbody.empty();
    if (data && data.length > 0) {
        data.forEach(item => {
            $tbody.append(renderFunction(item));
        });
    } else {
        $tbody.append('<tr><td colspan="10" class="text-center py-4">No hay datos disponibles</td></tr>');
    }
}

