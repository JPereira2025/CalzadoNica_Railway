// --- VERSIÓN 2.1 - CONEXIÓN Y SIN ERRORES (CORREGIDA) ---

// Configuración de la API
const API_BASE = 'http://localhost/Zapatos/endpoints/';

// Estado global de la aplicación
let currentUser = null;
let carritoFactura = [];
let descuentoAplicado = { porcentaje: 0, codigo: '' };
let facturaIdCounter = 1; // Variable agregada

// Inicialización de la aplicación
 $(document).ready(function() {
    checkSession();
    setupEventListeners();
    loadDashboardStats(); // Esta función necesita ser implementada
});

// --- VERIFICACIÓN DE SESIÓN ---
function checkSession() {
    const savedUser = sessionStorage.getItem('currentUser');
    if (savedUser) {
        currentUser = JSON.parse(savedUser);
        showApp();
    } else {
        showLogin();
    }
}

function showApp() {
    $("#loginModal").hide();
    $("#app").show();
    $("#user-name").text(currentUser.username);
    $("#user-role").text(currentUser.role);
}

function showLogin() {
    $("#app").hide();
    $("#loginModal").show();
}

// --- CONFIGURACIÓN DE EVENTOS ---
function setupEventListeners() {
    // Login y Logout
    $("#loginForm").on("submit", handleLogin);
    $("#logout-btn").on("click", handleLogout);

    // Navegación
    $(document).on("click", "a.sidebar-link", handleNavigation);

    // Modales
    $(".modal-close").on("click", function() {
        $(this).closest('.modal').fadeOut(200);
    });

    // Módulos (empleados, categorías, etc.)
    setupEmpleadosListeners();
    setupCategoriasListeners();
    setupEstilosListeners();
    setupProductosListeners();
    setupCodigosListeners();
    setupFacturacionListeners();
    setupUsuariosListeners();
}

// --- LÓGICA DE LOGIN ---
function handleLogin(e) {
    e.preventDefault();
    const username = $("#username").val().trim();
    const password = $("#password").val();

    const $submitBtn = $(e.target).find('button[type="submit"]');
    $submitBtn.prop('disabled', true).text('Iniciando...');

    // CORRECCIÓN: Cambiado a datos de formulario en lugar de JSON
    apiCall('login.php', 'POST', { username, password }, false)
        .then(response => {
            if (response.success) {
                currentUser = response.user;
                sessionStorage.setItem('currentUser', JSON.stringify(currentUser));
                showNotification(`Bienvenido, ${currentUser.username}!`, "success");
                showApp();
            } else {
                $("#loginError").removeClass("hidden").text(response.message);
            }
        })
        .fail(() => showNotification('Error de conexión. Revisa la consola (F12).', 'error'))
        .always(() => $submitBtn.prop('disabled', false).text('Iniciar Sesión'));
}

function handleLogout(e) {
    e.preventDefault();
    sessionStorage.removeItem('currentUser');
    currentUser = null;
    showLogin();
}

// --- LÓGICA DE NAVEGACIÓN (CORREGIDA) ---
function handleNavigation(e) {
    e = e || window.event;
    // Preferir currentTarget (delegación); si no, buscar <a> más cercano
    let $anchor = null;
    if (e.currentTarget && e.currentTarget.tagName && e.currentTarget.tagName.toUpperCase() === 'A') {
        $anchor = $(e.currentTarget);
    } else {
        $anchor = $(e.target).closest('a[href]');
    }
    if (!$anchor || $anchor.length === 0) return;

    const href = $anchor.attr('href') || '';
    if (!href) return;

    // Prevenir comportamiento por defecto sólo para anclas internas
    if (href.charAt(0) === '#') e.preventDefault();

    // Extraer target de forma segura (después del '#')
    let target = '';
    if (href.indexOf('#') !== -1) {
        target = href.split('#').pop() || '';
    } else {
        try {
            const url = new URL(href, window.location.origin);
            target = (url.hash || '').replace('#', '');
        } catch (err) {
            target = href.replace(/^.*#/, '');
        }
    }
    if (!target) return;

    if (typeof navigateTo === 'function') navigateTo(target);
}

function navigateTo(page) {
    $(".page").hide();
    $(`#${page}-page`).show();
    $("#page-title").text(capitalizeFirstLetter(page));
    $(".sidebar-link").removeClass("active");
    $(`a[href="#${page}"]`).addClass("active");
    
    if (page === 'facturacion') {
        resetFacturaForm();
        loadFacturas();
    } else if (page === 'dashboard') {
        loadDashboardStats();
    }
}

// --- FUNCIONES AUXILIARES ---
// CORRECCIÓN: Añadido parámetro para indicar si se envía como JSON o como formulario
function apiCall(endpoint, method = 'GET', data = null, asJson = true) {
    const options = {
        url: `${API_BASE}${endpoint}`,
        method: method,
        dataType: 'json'
    };
    
    if (data) {
        if (asJson) {
            options.data = JSON.stringify(data);
            options.contentType = 'application/json';
        } else {
            options.data = data;
        }
    }
    
    return $.ajax(options);
}

function showNotification(message, type = 'info') {
    const icons = { success: 'check-circle', error: 'times-circle', info: 'info-circle' };
    const colors = { success: 'bg-green-500', error: 'bg-red-500', info: 'bg-blue-500' };
    const notification = `
        <div class="notification ${colors[type]} text-white p-4 rounded-lg shadow-lg mb-4 flex items-center">
            <i class="fas fa-${icons[type]} mr-3"></i>
            <span>${message}</span>
        </div>
    `;
    $("#notification-area").append(notification);
    setTimeout(() => {
        $("#notification-area .notification").first().fadeOut(500, function() { $(this).remove(); });
    }, 5000);
}

function capitalizeFirstLetter(string) {
    return string.charAt(0).toUpperCase() + string.slice(1);
}

// --- FUNCIONES DE MODALES Y FORMULARIOS ---
function resetForm(formSelector, idSelector) {
    $(formSelector)[0].reset();
    if (idSelector) {
        $(idSelector).val('');
    }
}

function openModal(modalId) {
    $(modalId).fadeIn(200);
}

function resetAllForms() {
    resetForm('#form-empleado', '#empleado-id-form');
    resetForm('#form-categoria', '#categoria-id-form');
    resetForm('#form-estilo', '#estilo-id-form');
    resetForm('#form-producto', '#producto-id-form');
    resetForm('#form-codigo', '#codigo-id-form');
    resetForm('#form-usuario', '#usuario-id-form');
}

