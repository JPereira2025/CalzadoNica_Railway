# Example environment variables for Calzado Nica
# Copy this file to `.env` and fill with your local/production secrets.

# Database (example for local MySQL)
DB_HOST=127.0.0.1
DB_USER=root
DB_PASS=
DB_NAME=calzado_nica
DB_PORT=3306

# Alternatively, set a full DATABASE_URL for Postgres (Railway)
# DATABASE_URL="postgresql://username:password@host:port/database"

# JWT secret used to sign tokens
JWT_SECRET=change_this_secret

# Server
PORT=3001
HOST=0.0.0.0

# Email / SMTP (example using Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=you@example.com
EMAIL_PASS=your_email_password_or_app_password
EMAIL_FROM=no-reply@example.com

# Optional debug flag: if true, /resend-token may return token in response (local only)
DEBUG_RESEND=false
# Example environment variables (DO NOT commit secrets)
# Copy this file to `.env` and fill the values locally before running the app.

# Server
JWT_SECRET=change_this_secret
PORT=3001
HOST=0.0.0.0

# Database (MySQL example - Prisma uses DATABASE_URL)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@127.0.0.1:3306/calzado_nica"
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=calzado_nica

# Email (SMTP)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your@email.com
EMAIL_PASS=your_email_password
EMAIL_FROM=no-reply@example.com

# Optional: other variables used in the project
# NODE_ENV=development