<div id="dashboard-page" class="page">
<div class="bg-white rounded-lg shadow-md p-6">
<div class="mb-6">
<div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3">
<div>
<h2 class="text-2xl font-bold text-gray-800 mb-2">¡Bienvenido al Sistema!</h2>
<p class="text-gray-600 mb-4">Has iniciado sesión correctamente. Usa el menú de la izquierda para navegar.</p>
</div>
<p class="text-sm text-blue-500 italic text-right font-bold">  Jorge Alberto Pereira - Gerente General</p>
</div>
<p class="text-sm text-gray-500 italic">Calzado Nica - Tu tienda de confianza desde 1995</p>
</div>

<!-- Carrusel de imágenes -->
<div class="relative w-full h-96 overflow-hidden rounded-lg shadow-lg">
<!-- Contenedor de imágenes -->
<div class="carousel-container relative h-full">
<!-- Imagen 1: Zapatos Fila -->
<div class="carousel-slide absolute inset-0 transition-opacity duration-1000">
<img src="images/Fila_Shoes.jpg" alt="Zapatos Fila" class="w-full h-full object-cover">
<div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/70 to-transparent p-4">
<h3 class="text-white text-xl font-bold">Colección Fila</h3>
<p class="text-white/80">Estilo y comodidad para deportistas</p>
</div>
</div>

<!-- Imagen 2: Zapatos Reebok -->
<div class="carousel-slide absolute inset-0 transition-opacity duration-1000 opacity-0">
<img src="images/Reebok_Shoes.jpg" alt="Zapatos Reebok" class="w-full h-full object-cover">
<div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/70 to-transparent p-4">
<h3 class="text-white text-xl font-bold">Reebok Performance</h3>
<p class="text-white/80">Innovación y resistencia en cada paso</p>
</div>
</div>

<!-- Imagen 3: Zapatos Under Armour -->
<div class="carousel-slide absolute inset-0 transition-opacity duration-1000 opacity-0">
<img src="images/Underarmour_Shoes.jpg" alt="Zapatos Under Armour" class="w-full h-full object-cover">
<div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/70 to-transparent p-4">
<h3 class="text-white text-xl font-bold">Under Armour Elite</h3>
<p class="text-white/80">Tecnología avanzada para atletas</p>
</div>
</div>

<!-- Imagen 4: Zapatos Puma -->
<div class="carousel-slide absolute inset-0 transition-opacity duration-1000 opacity-0">
<img src="images/Puma_Shoes.jpg" alt="Zapatos Puma" class="w-full h-full object-cover">
<div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/70 to-transparent p-4">
<h3 class="text-white text-xl font-bold">Puma Sport</h3>
<p class="text-white/80">Estilo urbano y deportivo</p>
</div>
</div>

<!-- Imagen 5: Zapatos Adidas -->
<div class="carousel-slide absolute inset-0 transition-opacity duration-1000 opacity-0">
<img src="images/Adidas_Shoes.jpg" alt="Zapatos Adidas" class="w-full h-full object-cover">
<div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/70 to-transparent p-4">
<h3 class="text-white text-xl font-bold">Adidas Originals</h3>
<p class="text-white/80">Clásicos que nunca pasan de moda</p>
</div>
</div>
</div>

<!-- Controles del carrusel -->
<button id="prevBtn" class="absolute left-4 top-1/2 transform -translate-y-1/2 bg-black/30 text-white p-2 rounded-full hover:bg-black/50 transition-colors">
<i class="fas fa-chevron-left"></i>
</button>
<button id="nextBtn" class="absolute right-4 top-1/2 transform -translate-y-1/2 bg-black/30 text-white p-2 rounded-full hover:bg-black/50 transition-colors">
<i class="fas fa-chevron-right"></i>
</button>

<!-- Indicadores -->
<div class="absolute bottom-4 left-1/2 transform -translate-x-1/2 flex space-x-2">
<button class="carousel-indicator w-3 h-3 bg-white rounded-full opacity-70" data-slide="0"></button>
<button class="carousel-indicator w-3 h-3 bg-white/50 rounded-full" data-slide="1"></button>
<button class="carousel-indicator w-3 h-3 bg-white/50 rounded-full" data-slide="2"></button>
<button class="carousel-indicator w-3 h-3 bg-white/50 rounded-full" data-slide="3"></button>
<button class="carousel-indicator w-3 h-3 bg-white/50 rounded-full" data-slide="4"></button>
</div>
</div>

<!-- Estadísticas rápidas -->
<div class="grid grid-cols-1 md:grid-cols-4 gap-4 mt-8">
<div class="bg-blue-50 p-4 rounded-lg">
<div class="flex items-center">
<div class="p-3 bg-blue-500 rounded-full">
<i class="fas fa-shoe-prints text-white"></i>
</div>
<div class="ml-4">
<p class="text-sm text-gray-600">Productos</p>
<p class="text-xl font-bold text-gray-800" id="stat-productos">0</p>
</div>
</div>
</div>

<div class="bg-green-50 p-4 rounded-lg">
<div class="flex items-center">
<div class="p-3 bg-green-500 rounded-full">
<i class="fas fa-users text-white"></i>
</div>
<div class="ml-4">
<p class="text-sm text-gray-600">Empleados</p>
<p class="text-xl font-bold text-gray-800" id="stat-empleados">0</p>
</div>
</div>
</div>

<div class="bg-purple-50 p-4 rounded-lg">
<div class="flex items-center">
<div class="p-3 bg-purple-500 rounded-full">
<i class="fas fa-tags text-white"></i>
</div>
<div class="ml-4">
<p class="text-sm text-gray-600">Categorías</p>
<p class="text-xl font-bold text-gray-800" id="stat-categorias">0</p>
</div>
</div>
</div>

<div class="bg-orange-50 p-4 rounded-lg">
<div class="flex items-center">
<div class="p-3 bg-orange-500 rounded-full">
<i class="fas fa-palette text-white"></i>
</div>
<div class="ml-4">
<p class="text-sm text-gray-600">Estilos</p>
<p class="text-xl font-bold text-gray-800" id="stat-estilos">0</p>
</div>
</div>
</div>

<div class="bg-red-50 p-4 rounded-lg">
<div class="flex items-center">
<div class="p-3 bg-red-500 rounded-full">
<i class="fas fa-shopping-cart text-white"></i>
</div>
<div class="ml-4">
<p class="text-sm text-gray-600">Ventas del Mes (facturas)</p>
<p class="text-xl font-bold text-gray-800" id="stat-ventas">0</p>
</div>
</div>
</div>

<div class="bg-teal-50 p-4 rounded-lg">
<div class="flex items-center">
<div class="p-3 bg-teal-500 rounded-full">
<i class="fas fa-shoe-prints text-white"></i>
</div>
<div class="ml-4">
<p class="text-sm text-gray-600">Pares vendidos</p>
<p class="text-xl font-bold text-gray-800" id="stat-ventas-pares">0</p>
</div>
</div>
</div>

<div class="bg-yellow-50 p-4 rounded-lg">
<div class="flex items-center">
<div class="p-3 bg-yellow-500 rounded-full">
<i class="fas fa-dollar-sign text-white"></i>
</div>
<div class="ml-4">
<p class="text-sm text-gray-600">Ingresos</p>
<p class="text-xl font-bold text-gray-800" id="stat-ingresos">C$0</p>
</div>
</div>
</div>
</div>
</div>