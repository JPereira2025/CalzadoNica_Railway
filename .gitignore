# .gitignore
/vendor/
/node_modules/
.env
.env.*
.env.local
.env.development
.env.production
*.log
.DS_Store
/.idea/
/.vscode/
uploads/
config.php
db/*.sql
/src/generated/prisma

# Imágenes de productos (no persistir en git, se perderían en deploys)
/public/tienda/img/*
!/public/tienda/img/sin-imagen.svg
!/public/tienda/img/.gitkeep
!/public/tienda/img/calzado_nica_logo.png
!/public/tienda/img/logo_bordado.png
!/public/tienda/img/logo_cuero.png

# Imágenes de tienda folder
/tienda/img/*
!/tienda/img/sin-imagen.svg
!/tienda/img/.gitkeep
